# ============================================
# CREDIT CARD FRAUD DETECTION - .gitignore
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
*.egg-info/
dist/
build/
*.egg

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Data files (IMPORTANT: Do not commit sensitive data!)
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.json
data/processed/*.csv
data/processed/*.h5
data/processed/*.hdf5
data/external/*.csv

# Only keep .gitkeep to preserve folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Models (large files - should not be committed)
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.pth
models/*.onnx
models/*.pb

# Reports
reports/*.png
reports/*.jpg
reports/*.pdf

# Only keep .gitkeep
!models/.gitkeep
!reports/.gitkeep

# Environment variables
.env
.env.local
.env.*.local

# IDE / Editors
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Operating System files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Testing / Coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking (MyPy)
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre
.pyre/

# Backup files
*~
*.bak
*.swp

# Temporary files
tmp/
temp/
*.tmp